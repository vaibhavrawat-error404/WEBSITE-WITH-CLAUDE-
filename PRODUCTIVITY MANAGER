### Adding Export Functionality

```javascript
const exportData = () => {
  const data = {
    tasks,
    schedule,
    achievements,
    rewards,
    socialPlatforms,
    points
  };
  
  const dataStr = JSON.stringify(data, null, 2);
  const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
  
  const exportFileDefaultName = `productivity_${new Date().toISOString()}.json`;
  
  const linkElement = document.createElement('a');
  linkElement.setAttribute('href', dataUri);
  linkElement.setAttribute('download', exportFileDefaultName);
  linkElement.click();
};
```

### Adding Import Functionality

```javascript
const importData = (file) => {
  const reader = new FileReader();
  reader.onload = (e) => {
    const importedData = JSON.parse(e.target.result);
    
    setTasks(importedData.tasks || []);
    setSchedule(importedData.schedule || []);
    setAchievements(importedData.achievements || []);
    setRewards(importedData.rewards || []);
    setSocialPlatforms(importedData.socialPlatforms || []);
    setPoints(importedData.points || 0);
  };
  reader.readAsText(file);
};
```

### Adding Dark/Light Mode

```javascript
const [theme, setTheme] = useState('dark');

const toggleTheme = () => {
  setTheme(theme === 'dark' ? 'light' : 'dark');
  localStorage.setItem('theme', theme);
};

// Apply theme
useEffect(() => {
  document.documentElement.classList.toggle('dark', theme === 'dark');
}, [theme]);
```

